<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">



<suite parallel="tests" name="Suite1" verbose="1">
    <listeners>
        <listener class-name="E2E.TestComponents.Listeners"/>
    </listeners>

    <test name="Base_Level_Testing">
        <classes>
            <class name="E2E.FullTest.BaseTest"/>
        </classes>
    </test>

    <test name="Errors_Only">
        <classes>
            <class name="E2E.FullTest.ErrorTest">
                <methods>
                    <include name="errorValidation"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Regression_ALL_TESTS">
        <packages>
            <package name="E2E.FullTest"/>
        </packages>
    </test>
</suite>
